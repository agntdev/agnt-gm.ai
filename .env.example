# Frontend env (Vite).

# Builder API base. Override for staging/preview; in dev the Vite proxy
# forwards /api → https://api.agnt-gm.ai when this is left as the default.
VITE_API_BASE=/api

# Platform TON wallet — destination for project reward-pool funding via
# TonConnect. Must match PLATFORM_TON_WALLET_ADDRESS on the API server,
# otherwise the deposit watcher will never auto-confirm the project.
# Accepts any TON address format (raw, EQ, UQ).
VITE_TON_PLATFORM_WALLET=
